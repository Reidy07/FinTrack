@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/10 text-emerald-400 mb-4">
                <i class="bi bi-key text-3xl"></i>
            </div>
            <h1 class="text-2xl font-bold text-white mb-2">¿Olvidaste tu contraseña?</h1>
            <p class="text-white/50 text-sm">Ingresa tu correo electrónico y te enviaremos las instrucciones para restablecerla.</p>
        </div>

        <div class="p-8 rounded-2xl bg-white/5 border border-white/10 shadow-xl backdrop-blur-sm">
            <form method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="p-3 bg-red-500/10 border border-red-500/20 text-red-200 rounded-lg text-sm mb-4" role="alert"></div>

                <div>
                    <label asp-for="Input.Email" class="block text-sm text-white/60 mb-2">Correo Electrónico</label>
                    <input asp-for="Input.Email" class="ft-input" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" />
                    <span asp-validation-for="Input.Email" class="text-xs text-red-400 mt-1 block"></span>
                </div>

                <button type="submit" class="ft-btn-primary w-full justify-center py-2.5">Enviar enlace de recuperación</button>
            </form>
        </div>

        <div class="text-center mt-6">
            <a asp-page="./Login" class="text-sm text-emerald-400 hover:text-emerald-300 transition">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
