@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
    Layout = "/Views/Shared/_AuthLayout.cshtml";
}


<div class="w-full max-w-md">
    <div class="backdrop-blur-xl shadow-2xl p-1 md:p-2">
        <section class="ft-login ft-login--compact">
            <div class="ft-login__header">
                <span class="ft-login__eyebrow">
                    <i class="bi bi-shield-lock"></i>
                    Acceso seguro
                </span>

                <h1 class="ft-login__title">Recuperar Contraseña</h1>
            </div>
            <form method="post" class="ft-login__form">
                <div asp-validation-summary="ModelOnly" class="ft-validation" role="alert"></div>

                <div class="ft-login__field">
                    <label asp-for="Input.Email" class="ft-label"></label>
                    <div class="ft-input-wrap">
                        <span class="ft-input-icon">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Input.Email"
                               class="ft-input ft-input--with-icon"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="correo@ejemplo.com" />
                    </div>
                </div>
                <button type="submit" class="ft-btn ft-btn-primary ft-btn-block ft-login__submit">Reset Password</button>

                <!-- Botón para volver -->
                <a asp-page="./Login" class="ft-btn-primary2 w-full flex items-center justify-center py-3 mt-6">
                    Volver a Iniciar Sesión <i class="bi bi-arrow-right ml-2"></i>
                </a>
            </form>
            </section>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
