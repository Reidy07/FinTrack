@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "/Views/Shared/_AuthLayout.cshtml";
}

<section class="ft-login ft-login--compact">
    <div class="ft-login__header">
        <span class="ft-login__eyebrow">
            <i class="bi bi-shield-lock"></i>
            Acceso seguro
        </span>
    </div>
    <form id="account" method="post" class="ft-login__form">
        <div asp-validation-summary="ModelOnly" class="ft-validation" role="alert"></div>

        <div class="ft-login__field">
            <label asp-for="Input.Email" class="ft-label"></label>
            <div class="ft-input-wrap">
                <span class="ft-input-icon">
                    <i class="bi bi-envelope"></i>
                </span>
                <input asp-for="Input.Email"
                       class="ft-input ft-input--with-icon"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="correo@ejemplo.com" />
            </div>
            <span asp-validation-for="Input.Email" class="ft-validation"></span>
        </div>

        <div class="ft-login__field">
            <div class="ft-login__label-row">
                <label asp-for="Input.Password" class="ft-label"></label>
                <button type="button" id="togglePwd"
                        class="righ-2 top-1/2 -translate-y-1/2 px-3 py-2 rounded-xl text-white/60 hover:text-white hover:bg-white/5">
                    <i class="bi bi-eye"></i>
                </button>
            </div>

            <div class="ft-input-wrap">
                <span class="ft-input-icon">
                    <i class="bi bi-lock"></i>
                </span>
                <input asp-for="Input.Password"
                       class="ft-input ft-input--with-icon"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="Tu contraseña" />
            </div>
            <div class=" absft-login__label-row">
                <a id="forgot-password" asp-page="./ForgotPassword" class="ft-login__link">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>
            <span asp-validation-for="Input.Password" class="ft-validation"></span>
        </div>


        <button id="login-submit" type="submit" class="ft-btn ft-btn-primary ft-btn-block ft-login__submit">
            <i class="bi bi-box-arrow-in-right"></i>
            Iniciar sesión
        </button>

        <div class="ft-login__footer">
            <p class="ft-text-muted">
                ¿No tienes cuenta?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="ft-login__link">
                    Regístrate
                </a>
            </p>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const btn = document.getElementById('togglePwd');
            const input = document.getElementById('Input_Password');
            if (!btn || !input) return;

            btn.addEventListener('click', () => {
                const isPwd = input.getAttribute('type') === 'password';
                input.setAttribute('type', isPwd ? 'text' : 'password');
                btn.innerHTML = isPwd ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
            });
        })();
    </script>
}
