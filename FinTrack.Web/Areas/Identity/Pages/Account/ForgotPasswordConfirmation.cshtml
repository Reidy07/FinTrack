@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Correo Enviado";
}

<div class="text-center mb-8">
    <div class="h-12 w-12 rounded-2xl bg-blue-500/20 border border-blue-500/30 flex items-center justify-center mx-auto mb-4 shadow-[0_0_15px_rgba(59,130,246,0.2)]">
        <i class="bi bi-envelope-check text-blue-400 text-2xl"></i>
    </div>
    <h1 class="text-2xl font-bold text-white tracking-tight">Revisa tu bandeja</h1>
</div>

<div class="text-center space-y-6">
    <p class="text-sm text-white/70 leading-relaxed">
        Hemos enviado un correo electrónico con las instrucciones para tu cuenta.
        Por favor, revisa tu bandeja de entrada (o la carpeta de spam).
    </p>

    <!-- Botón para volver -->
    <a asp-page="./Login" class="ft-btn-primary2 w-full flex items-center justify-center py-3 mt-6">
        Volver a Iniciar Sesión <i class="bi bi-arrow-right ml-2"></i>
    </a>
</div>