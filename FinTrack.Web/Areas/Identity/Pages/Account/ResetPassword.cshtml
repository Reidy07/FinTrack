@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-white mb-2">Crea una nueva contraseña</h1>
            <p class="text-white/50 text-sm">Ingresa tu correo y tu nueva contraseña para recuperar el acceso a tu cuenta.</p>
        </div>

        <div class="p-8 rounded-2xl bg-white/5 border border-white/10 shadow-xl backdrop-blur-sm">
            <form method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="p-3 bg-red-500/10 border border-red-500/20 text-red-200 rounded-lg text-sm mb-4" role="alert"></div>

                <input asp-for="Input.Code" type="hidden" />

                <div>
                    <label asp-for="Input.Email" class="block text-sm text-white/60 mb-2">Correo Electrónico</label>
                    <input asp-for="Input.Email" class="ft-input opacity-70" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" readonly />
                    <span asp-validation-for="Input.Email" class="text-xs text-red-400 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="block text-sm text-white/60 mb-2">Nueva Contraseña</label>
                    <input asp-for="Input.Password" class="ft-input" autocomplete="new-password" aria-required="true" placeholder="Mínimo 8 caracteres" />
                    <span asp-validation-for="Input.Password" class="text-xs text-red-400 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-sm text-white/60 mb-2">Confirmar Contraseña</label>
                    <input asp-for="Input.ConfirmPassword" class="ft-input" autocomplete="new-password" aria-required="true" placeholder="Repite tu contraseña" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-400 mt-1 block"></span>
                </div>

                <button type="submit" class="ft-btn-primary w-full justify-center py-2.5">Guardar nueva contraseña</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

