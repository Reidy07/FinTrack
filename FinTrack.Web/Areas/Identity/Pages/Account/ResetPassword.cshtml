@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="max-w-md mx-auto w-full mt-8">

    <!-- Encabezado Visual -->
    <div class="text-center mb-8">
        <div class="h-14 w-14 rounded-2xl bg-emerald-400/10 border border-emerald-400/20 flex items-center justify-center mx-auto mb-4 shadow-[0_0_20px_rgba(52,211,153,0.15)]">
            <i class="bi bi-shield-lock text-emerald-400 text-2xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-white tracking-tight">Nueva Contraseña</h1>
        <p class="text-sm text-white/50 mt-2">Crea una nueva contraseña segura para tu cuenta</p>
    </div>

    <!-- Formulario -->
    <form method="post" class="space-y-5 ft-surface p-6 sm:p-8 border border-white/10 shadow-2xl">

        <div asp-validation-summary="ModelOnly" class="text-sm text-red-400 bg-red-400/10 border border-red-400/20 rounded-xl p-3" role="alert"></div>
        <input asp-for="Input.Code" type="hidden" />

        <!-- CAMPO: EMAIL -->
        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-white/70 mb-2">Correo Electrónico</label>
            <!-- Contenedor Relative Nativo -->
            <div style="position: relative; display: block; width: 100%;">
                <!-- Ícono Absolute Nativo y Centrado Verticalmente -->
                <i class="bi bi-envelope" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); pointer-events: none; font-size: 1.1rem;"></i>

                <input asp-for="Input.Email" class="ft-input" style="padding-left: 44px !important; width: 100%;" autocomplete="username" aria-required="true" placeholder="ejemplo@correo.com" />
            </div>
            <span asp-validation-for="Input.Email" class="text-xs text-red-400 mt-1.5 block font-medium"></span>
        </div>

        <!-- CAMPO: NUEVA CONTRASEÑA -->
        <div>
            <label asp-for="Input.Password" class="block text-sm font-medium text-white/70 mb-2">Nueva Contraseña</label>
            <div style="position: relative; display: block; width: 100%;">
                <i class="bi bi-key" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); pointer-events: none; font-size: 1.1rem;"></i>

                <input asp-for="Input.Password" type="password" class="ft-input" style="padding-left: 44px !important; width: 100%;" autocomplete="new-password" aria-required="true" placeholder="Mínimo 6 caracteres" />
            </div>
            <span asp-validation-for="Input.Password" class="text-xs text-red-400 mt-1.5 block font-medium"></span>
        </div>

        <!-- CAMPO: CONFIRMAR CONTRASEÑA -->
        <div>
            <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-white/70 mb-2">Confirmar Nueva Contraseña</label>
            <div style="position: relative; display: block; width: 100%;">
                <i class="bi bi-shield-check" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); pointer-events: none; font-size: 1.1rem;"></i>

                <input asp-for="Input.ConfirmPassword" type="password" class="ft-input" style="padding-left: 44px !important; width: 100%;" autocomplete="new-password" aria-required="true" placeholder="Repite la contraseña" />
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-400 mt-1.5 block font-medium"></span>
        </div>

        <!-- BOTÓN -->
        <button type="submit" class="ft-btn-primary w-full justify-center py-3 mt-4 text-sm font-bold shadow-[0_0_15px_rgba(52,211,153,0.2)]">
            Guardar contraseña <i class="bi bi-check2-circle ml-2 text-lg"></i>
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}