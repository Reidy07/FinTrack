@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="ft-page max-w-2xl mx-auto">

    <div class="ft-header mb-6">
        <div>
            <h1 class="ft-header-title">@ViewData["Title"]</h1>
            <p class="ft-header-sub">Asegúrate de usar una contraseña fuerte y única</p>
        </div>

        <a asp-page="./Index" class="ft-btn-secondary">
            <i class="bi bi-arrow-left mr-2"></i>
            Volver
        </a>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <section class="ft-section">
        <form id="change-password-form" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="p-3 bg-red-500/10 border border-red-500/20 text-red-200 rounded-lg text-sm mb-4" role="alert"></div>

            <div>
                <label asp-for="Input.OldPassword" class="block text-sm text-white/60 mb-2">Contraseña Actual</label>
                <input asp-for="Input.OldPassword" class="ft-input" autocomplete="current-password" aria-required="true" placeholder="Ingresa tu contraseña actual" />
                <span asp-validation-for="Input.OldPassword" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Input.NewPassword" class="block text-sm text-white/60 mb-2">Nueva Contraseña</label>
                <input asp-for="Input.NewPassword" class="ft-input" autocomplete="new-password" aria-required="true" placeholder="Ingresa tu nueva contraseña" />
                <span asp-validation-for="Input.NewPassword" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword" class="block text-sm text-white/60 mb-2">Confirmar Nueva Contraseña</label>
                <input asp-for="Input.ConfirmPassword" class="ft-input" autocomplete="new-password" aria-required="true" placeholder="Confirma tu nueva contraseña" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <div class="pt-4 border-t border-white/10 flex justify-end">
                <button type="submit" class="ft-btn-primary px-8">Actualizar Contraseña</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}