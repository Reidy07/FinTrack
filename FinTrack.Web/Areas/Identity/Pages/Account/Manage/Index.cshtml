@page
@using FinTrack.Infrastructure.Identity
@using FinTrack.Web.Areas.Identity.Pages.Account.Manage

@inject UserManager<ApplicationUser> UserManager

@model IndexModel
@{
    ViewData["Title"] = "Mi Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = await UserManager.GetUserAsync(User);
    var initial = !string.IsNullOrEmpty(user?.FirstName) ? user.FirstName.Substring(0, 1).ToUpper() : "U";
}

<div class="ft-page max-w-4xl mx-auto">

    <!-- Encabezado -->
    <div class="ft-header mb-8">
        <div>
            <h1 class="ft-header-title">@ViewData["Title"]</h1>
            <p class="ft-header-sub">Gestiona tu información personal y preferencias</p>
        </div>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <!-- SECCIÓN 1: Información Personal -->
    <div class="ft-section mb-8">
        <form id="profile-form" method="post">

            <!-- Cabecera del Perfil (Avatar arreglado) -->
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 mb-8 pb-8 border-b border-white/10">
                <!-- Avatar fijo -->
                <div class="h-24 w-24 flex-none rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-4xl font-bold shadow-lg">
                    @initial
                </div>

                <div class="flex-1 text-center sm:text-left mt-2">
                    <h2 class="text-2xl font-bold text-white mb-1">@user?.FirstName @user?.LastName</h2>
                    <p class="text-white/60 mb-3 text-sm">@user?.Email</p>

                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-xs font-medium text-white/70">
                        <i class="bi bi-calendar3 text-emerald-500"></i>
                        Miembro desde @user?.CreatedAt.ToString("MMMM yyyy")
                    </div>
                </div>
            </div>

            <!-- Grid de Inputs (Con mejor espaciado: space-y-2) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6 mb-8">
                <div class="space-y-2">
                    <label asp-for="Input.FirstName" class="block text-sm font-medium text-white/80">Nombre</label>
                    <input asp-for="Input.FirstName" class="ft-input w-full" placeholder="Tu nombre" />
                    <span asp-validation-for="Input.FirstName" class="text-xs text-red-400"></span>
                </div>


                <div class="space-y-2">
                    <label asp-for="Input.LastName" class="block text-sm font-medium text-white/80">Apellido</label>
                    <input asp-for="Input.LastName" class="ft-input w-full" placeholder="Tu apellido" />
                    <span asp-validation-for="Input.LastName" class="text-xs text-red-400"></span>
                </div>

                <div class="md:col-span-2 space-y-2">
                    <label asp-for="Username" class="block text-sm font-medium text-white/80">Usuario / Correo Electrónico</label>
                    <input asp-for="Username" class="ft-input w-full opacity-50 cursor-not-allowed" disabled />
                    <p class="text-xs text-white/50 mt-2 flex items-center gap-1.5">
                        <i class="bi bi-info-circle text-blue-400"></i>
                        El correo electrónico no se puede cambiar por motivos de seguridad.
                    </p>
                </div>
            </div>

            <!-- Botón Guardar -->
            <div class="flex justify-end pt-6 border-t border-white/10">
                <button id="update-profile-button" type="submit" class="ft-btn-primary px-8 py-2.5">
                    Guardar Cambios
                </button>
            </div>

        </form>
    </div>

    <!-- SECCIÓN 2: Seguridad -->
    <div class="ft-section mb-8">
        <h3 class="text-lg font-semibold text-white mb-4">Seguridad</h3>

        <div class="flex items-center justify-between p-5 rounded-xl bg-white/5 border border-white/10">
            <div class="flex items-center gap-4">
                <div class="h-12 w-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/70">
                    <i class="bi bi-shield-lock text-xl"></i>

                </div>
                <div>
                    <p class="font-semibold text-white">Cambiar Contraseña</p>
                    <p class="text-sm text-white/50 mt-1">Actualiza tu contraseña regularmente</p>
                </div>
            </div>
            <a asp-page="./ChangePassword" class="ft-btn-secondary text-sm px-4">Modificar</a>
        </div>
    </div>

    <!-- SECCIÓN 3: Datos y Privacidad -->
    <div class="ft-section mb-8">
        <h3 class="text-lg font-semibold text-white mb-2">Datos y Privacidad</h3>
        <p class="text-sm text-white/50 mb-6">Todos tus datos se almacenan de forma segura. Puedes exportarlos o eliminarlos permanentemente.</p>

        <div class="flex flex-col sm:flex-row gap-4">
            <a asp-controller="Reports" asp-action="ExportPdf" class="ft-btn-secondary text-center flex-1 justify-center py-2.5">
                <i class="bi bi-download mr-2"></i> Exportar datos
            </a>
            <a asp-page="DeletePersonalData" class="flex-1 text-center py-2.5 px-4 rounded-lg font-semibold text-red-400 bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 transition-colors">
                <i class="bi bi-trash mr-2"></i> Eliminar cuenta
            </a>
        </div>
    </div>

    <!-- SECCIÓN 4: Cerrar Sesión -->
    <div class="ft-section flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
            <h3 class="font-semibold text-white mb-1">Cerrar Sesión</h3>
            <p class="text-sm text-white/50">Salir de tu cuenta en este dispositivo</p>
        </div>
        <form class="w-full sm:w-auto" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Dashboard", new { area = "" })">
            <button type="submit" class="w-full sm:w-auto px-6 py-2.5 rounded-lg font-semibold text-white bg-red-500 hover:bg-red-600 transition-colors border border-red-600 shadow-sm">
                Cerrar Sesión
            </button>
        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}