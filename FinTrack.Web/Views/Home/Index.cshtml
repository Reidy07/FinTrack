@{
    ViewData["Title"] = "Bienvenido a FinTrack";
    Layout = null;
}

<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - FinTrack</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="ft-app-bg">
    <div class="ft-app-grid" aria-hidden="true"></div>

    <div class="ft-app-shell">
        <main class="ft-project-home">
            <section class="ft-project-home__hero" aria-label="Portada principal de FinTrack">
                <div class="ft-project-home__hero-card">
                    <div class="ft-project-home__hero-grid">
                        <div class="ft-project-home__content">
                            <span class="ft-project-home__eyebrow">
                                Sistema web de finanzas personales
                            </span>

                            <h1 class="ft-project-home__title">
                                FinTrack
                            </h1>

                            <p class="ft-project-home__lead">
                                Plataforma web orientada al registro, análisis y visualización de ingresos y gastos,
                                incorporando reportes, alertas y un módulo de inteligencia artificial predictiva
                                para apoyar la toma de decisiones financieras.
                            </p>

                            <div class="ft-project-home__highlights">
                                <div class="ft-project-home__highlight">
                                    <i class="bi bi-cash-coin"></i>
                                    <span>Control de ingresos y gastos</span>
                                </div>
                                <div class="ft-project-home__highlight">
                                    <i class="bi bi-bar-chart-line"></i>
                                    <span>Reportes y visualización</span>
                                </div>
                                <div class="ft-project-home__highlight">
                                    <i class="bi bi-cpu"></i>
                                    <span>Predicción y recomendaciones</span>
                                </div>
                            </div>

                            <div class="ft-project-home__actions">
                                <a asp-area="Identity" asp-page="/Account/Login" class="ft-home-btn ft-home-btn--primary">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                    Iniciar sesión
                                </a>

                                <a asp-area="Identity" asp-page="/Account/Register" class="ft-home-btn ft-home-btn--secondary">
                                    <i class="bi bi-person-plus"></i>
                                    Crear cuenta
                                </a>

                                <a href="#sobre-proyecto" class="ft-home-btn ft-project-home__btn-ghost">
                                    <i class="bi bi-info-circle"></i>
                                    Ver proyecto
                                </a>
                            </div>
                        </div>

                        <aside class="ft-project-home__panel">
                            <div class="ft-project-home__logo-box">
                                <img src="~/images/fintrack-logo.jpg"
                                     asp-append-version="true"
                                     alt="Logo de FinTrack"
                                     class="ft-project-home__logo" />
                            </div>

                            <div class="ft-project-home__mini-stats">
                                <div class="ft-project-home__stat">
                                    <strong>Gestión financiera</strong>
                                    <span>Registro y clasificación de movimientos.</span>
                                </div>
                                <div class="ft-project-home__stat">
                                    <strong>Visualización</strong>
                                    <span>Reportes claros para entender hábitos de gasto.</span>
                                </div>
                                <div class="ft-project-home__stat">
                                    <strong>IA predictiva</strong>
                                    <span>Proyecciones, alertas y recomendaciones.</span>
                                </div>
                            </div>
                        </aside>
                    </div>
                </div>
            </section>

            <section id="sobre-proyecto" class="ft-project-home__section">
                <div class="ft-project-home__section-card">
                    <div class="ft-project-home__section-head">
                        <span class="ft-project-home__section-eyebrow">Sobre el proyecto</span>
                        <h2>¿Qué ofrece FinTrack?</h2>
                        <p>
                            FinTrack fue concebido como una solución para mejorar la administración de finanzas
                            personales mediante una aplicación web intuitiva, segura y orientada al análisis.
                        </p>
                    </div>

                    <div class="ft-project-home__features-grid">
                        <article class="ft-project-home__feature-card">
                            <div class="ft-project-home__feature-icon">
                                <i class="bi bi-wallet2"></i>
                            </div>
                            <h3>Registro financiero</h3>
                            <p>
                                Permite registrar ingresos y gastos de manera estructurada, facilitando
                                el control diario de las finanzas personales.
                            </p>
                        </article>

                        <article class="ft-project-home__feature-card">
                            <div class="ft-project-home__feature-icon">
                                <i class="bi bi-pie-chart"></i>
                            </div>
                            <h3>Reportes visuales</h3>
                            <p>
                                Presenta resúmenes y gráficos que ayudan a interpretar la situación
                                financiera del usuario.
                            </p>
                        </article>

                        <article class="ft-project-home__feature-card">
                            <div class="ft-project-home__feature-icon">
                                <i class="bi bi-graph-up-arrow"></i>
                            </div>
                            <h3>Predicción de gastos</h3>
                            <p>
                                Emplea inteligencia artificial para estimar comportamientos futuros
                                y generar recomendaciones personalizadas.
                            </p>
                        </article>

                        <article class="ft-project-home__feature-card">
                            <div class="ft-project-home__feature-icon">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                            <h3>Acceso seguro</h3>
                            <p>
                                Incorpora autenticación y resguardo de datos para brindar una experiencia
                                confiable al usuario.
                            </p>
                        </article>
                    </div>
                </div>
            </section>

            <section class="ft-project-home__section">
                <div class="ft-project-home__section-card">
                    <div class="ft-project-home__section-head">
                        <span class="ft-project-home__section-eyebrow">Base tecnológica</span>
                        <h2>Tecnologías principales</h2>
                        <p>
                            El proyecto integra tecnologías orientadas al desarrollo web moderno,
                            persistencia de datos, visualización y análisis predictivo.
                        </p>
                    </div>

                    <div class="ft-project-home__tech-grid">
                        <div class="ft-project-home__tech-item">ASP.NET Core MVC</div>
                        <div class="ft-project-home__tech-item">ASP.NET Core Web API</div>
                        <div class="ft-project-home__tech-item">Entity Framework Core</div>
                        <div class="ft-project-home__tech-item">SQL Server</div>
                        <div class="ft-project-home__tech-item">ML.NET</div>
                        <div class="ft-project-home__tech-item">Chart.js</div>
                        <div class="ft-project-home__tech-item">Bootstrap 5</div>
                        <div class="ft-project-home__tech-item">C#</div>
                    </div>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
