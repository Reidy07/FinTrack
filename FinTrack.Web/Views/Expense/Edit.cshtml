@model FinTrack.Core.DTOs.ExpenseDto
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Editar gasto";
}

<div class="ft-page">
    <div class="ft-header">
        <div>
            <div class="ft-header-title">Editar gasto</div>
            <div class="ft-header-sub">Actualiza el registro</div>
        </div>

        <a asp-action="Index" class="ft-btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Volver
        </a>
    </div>

    <section class="ft-section max-w-3xl">
        <form asp-action="Edit" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-sm text-red-200"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm text-white/60 mb-2">Monto</label>
                    <input asp-for="Amount" type="number" step="0.01" class="ft-input" />
                    <span asp-validation-for="Amount" class="text-xs text-red-200"></span>
                </div>

                <div>
                    <label class="block text-sm text-white/60 mb-2">Fecha</label>
                    <input asp-for="Date" type="date" class="ft-input" />
                    <span asp-validation-for="Date" class="text-xs text-red-200"></span>
                </div>
            </div>

            <div>
                <label class="block text-sm text-white/60 mb-2">Descripción</label>
                <input asp-for="Description" class="ft-input" />
                <span asp-validation-for="Description" class="text-xs text-red-200"></span>
            </div>

            <div>
                <label class="block text-sm text-white/60 mb-2">Categoría</label>
                <select asp-for="CategoryId" class="ft-input" asp-items="ViewBag.Categories">
                    <option value="">Selecciona una categoría</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-xs text-red-200"></span>
            </div>

            <!-- Bloque Recurrencia -->
            <div class="p-4 rounded-xl bg-white/5 border border-white/10 mt-4 space-y-4">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input asp-for="IsRecurring" type="checkbox" id="chkRecurring" class="h-5 w-5 rounded border-white/20 bg-transparent text-amber-500 focus:ring-0 focus:ring-offset-0 transition" onchange="togglePattern(this, 'patternWrapper')" />
                    <span class="text-sm font-medium text-white/80">Este es un gasto recurrente</span>
                </label>

                <div id="patternWrapper" style="display: none;">
                    <label class="block text-sm text-white/60 mb-2">Frecuencia</label>
                    <select asp-for="RecurringPattern" class="ft-input">
                        <option value="">Selecciona la frecuencia</option>
                        <option value="Diario">Diario</option>
                        <option value="Semanal">Semanal</option>
                        <option value="Mensual">Mensual</option>
                        <option value="Anual">Anual</option>
                    </select>
                </div>
            </div>

            <div class="ft-divider pt-5"></div>

            <div class="flex items-center justify-end gap-2">
                <a asp-action="Index" class="ft-btn-secondary">Cancelar</a>
                <button type="submit" class="ft-btn-primary px-5">Guardar cambios</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePattern(checkbox, wrapperId) {
            const wrapper = document.getElementById(wrapperId);
            if (checkbox.checked) {
                wrapper.style.display = 'block';
            } else {
                wrapper.style.display = 'none';
                wrapper.querySelector('select').value = '';
            }
        }
        document.addEventListener("DOMContentLoaded", () => {
            togglePattern(document.getElementById('chkRecurring'), 'patternWrapper');
        });
    </script>
}
