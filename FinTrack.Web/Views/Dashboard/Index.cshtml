@using Microsoft.AspNetCore.Identity
@using FinTrack.Infrastructure.Identity
@using FinTrack.Web.ViewModels
@using System.Globalization
@using System.Text.Json

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";

    var user = await UserManager.GetUserAsync(User);
    var firstName = user?.FirstName ?? User.Identity?.Name ?? "Usuario";

    var culture = new CultureInfo("es-DO");

    string FormatCurrency(decimal value) => value.ToString("C", culture);

    string GetSeverityClasses(string severity)
    {
        return severity?.ToLower() switch
        {
            "critical" => "bg-red-500/10 text-red-300 border border-red-500/20",
            "warning" => "bg-yellow-500/10 text-yellow-300 border border-yellow-500/20",
            "info" => "bg-sky-500/10 text-sky-300 border border-sky-500/20",
            _ => "bg-white/5 text-white/80 border border-white/10"
        };
    }

    var chartJson = JsonSerializer.Serialize(new
    {
        labels = Model?.Summary?.ChartLabels ?? new List<string>(),
        income = Model?.Summary?.ChartIncomeData ?? new List<decimal>(),
        expense = Model?.Summary?.ChartExpenseData ?? new List<decimal>(),
        categories = Model?.Summary?.CategorySummaries?.Select(x => new
        {
            name = x.CategoryName,
            amount = x.Amount,
            percentage = x.Percentage
        }) ?? Enumerable.Empty<object>()
    });
}

<div class="ft-page">
    <div class="ft-header">
        <div>
            <div class="ft-header-title">¡Bienvenido, @firstName!</div>
            <div class="ft-header-sub">
                Resumen financiero de @Model.ReferenceMonthLabel
            </div>
        </div>

        <div class="ft-badge">
            <span class="ft-badge-dot"></span>
            Actualizado al @Model.ReferenceDate.ToString("dd/MM/yyyy HH:mm")
        </div>
    </div>

    @if (!Model.HasData)
    {
        <section class="ft-empty">
            <div class="ft-empty-title">Todavía no hay datos para mostrar</div>
            <div class="ft-empty-sub">
                Registra ingresos y gastos para que el dashboard pueda calcular tus indicadores, categorías, alertas y tendencias.
            </div>
        </section>
    }
    else
    {
        <!-- TIP DE IA LOCAL -->
        @if (!string.IsNullOrEmpty(Model.Summary.QuickTip))
        {
            <div class="bg-gradient-to-r from-emerald-500/20 to-blue-500/10 border border-emerald-500/20 rounded-2xl p-5 flex items-start sm:items-center gap-4 relative overflow-hidden mb-2">
                <div class="absolute right-0 top-0 opacity-10 blur-2xl w-32 h-32 bg-emerald-400 rounded-full"></div>
                <div class="h-10 w-10 shrink-0 rounded-xl bg-emerald-400/20 flex items-center justify-center border border-emerald-400/30">
                    <i class="bi bi-robot text-emerald-400 text-xl"></i>
                </div>
                <div>
                    <div class="text-xs font-bold tracking-wider text-emerald-400 mb-1 uppercase">FinBot Tip (Análisis Local)</div>
                    <div class="text-sm text-white/90 leading-relaxed">@Model.Summary.QuickTip</div>
                </div>
            </div>
        }

        <!-- 4 KPIs SUPERIORES -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            <div class="ft-kpi bg-success">
                <div class="ft-kpi-title">Ingresos del mes</div>
                <div class="ft-kpi-value text-emerald-400">@FormatCurrency(Model.Summary.TotalIncome)</div>
            </div>

            <div class="ft-kpi bg-danger">
                <div class="ft-kpi-title">Gastos del mes</div>
                <div class="ft-kpi-value text-red-400">@FormatCurrency(Model.Summary.TotalExpenses)</div>
            </div>

            <div class="ft-kpi bg-primary border border-blue-500/20">
                <div class="ft-kpi-title text-blue-200">Balance Total Acumulado</div>
                <div class="ft-kpi-value @(Model.CurrentBalance < 0 ? "text-red-400" : "text-white")">
                    @FormatCurrency(Model.CurrentBalance)
                </div>
            </div>

            <div class="ft-kpi">
                <div class="ft-kpi-title">Tasa de ahorro</div>
                <div class="ft-kpi-value">@Model.SavingsRate.ToString("N2")%</div>
            </div>
        </div>

        <!-- GRÁFICA PRINCIPAL (100% ancho) -->
        <section class="ft-section w-full">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                    <div class="ft-section-title">Ingresos vs gastos</div>
                    <div class="ft-section-sub">Evolución de los últimos 6 meses</div>
                </div>
            </div>

            <div class="relative w-full" style="height: 320px;">
                <canvas id="dashboardChart"></canvas>
            </div>
        </section>

        <!-- BLOQUE INFERIOR: 50% Análisis de Gastos | 50% Alertas y Pagos -->
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 items-start">

            <!-- WIDGET A LA IZQUIERDA -->
            <section class="ft-section">
                <div class="ft-section-title">Análisis de gastos</div>
                <div class="ft-section-sub mb-4">Distribución por categoría y balance neto mensual</div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <div class="rounded-2xl border border-white/10 p-4 bg-white/5">
                        <div class="text-sm text-white/70 mb-3">Gastos por categoría</div>
                        <div class="relative w-full" style="height: 280px;">
                            <canvas id="categoryExpenseChart"></canvas>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-white/10 p-4 bg-white/5">
                        <div class="text-sm text-white/70 mb-3">Balance neto por mes</div>
                        <div class="relative w-full" style="height: 280px;">
                            <canvas id="netBalanceChart"></canvas>
                        </div>
                    </div>
                </div>

                @if (Model.Summary.CategorySummaries.Any())
                {
                    <div class="mt-4 space-y-2">
                        @foreach (var item in Model.Summary.CategorySummaries.Take(5))
                        {
                            <div class="flex items-center justify-between text-sm border-b border-white/5 pb-2">
                                <span>@item.CategoryName</span>
                                <span class="text-white/70">
                                    @FormatCurrency(item.Amount) · @item.Percentage.ToString("N2")%
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-sm text-white/60 mt-4">
                        No hay gastos registrados por categoría en este mes.
                    </div>
                }
            </section>

            <!-- DOS WIDGETS PEQUEÑOS A LA DERECHA (Apilados verticalmente) -->
            <div class="flex flex-col gap-4">

                <!-- 1. Alertas Recientes -->
                <section class="ft-section flex-1">
                    <div class="flex items-center justify-between mb-4 border-b border-white/10 pb-3">
                        <h3 class="text-base font-semibold">Alertas Recientes</h3>
                        <a asp-controller="Alerts" asp-action="Index" class="text-xs text-emerald-400 hover:underline">Ver todas</a>
                    </div>

                    @if (Model.Summary.RecentAlerts != null && Model.Summary.RecentAlerts.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var alert in Model.Summary.RecentAlerts.Take(3))
                            {
                                var iconInfo = alert.Severity == "Critical" ? ("bi-exclamation-triangle-fill", "text-red-400", "bg-red-400/10") :
                                alert.Severity == "Warning" ? ("bi-exclamation-circle-fill", "text-amber-400", "bg-amber-400/10") :
                                ("bi-info-circle-fill", "text-blue-400", "bg-blue-400/10");

                                <div class="flex gap-3 p-3 rounded-xl border border-white/5 bg-white/5">
                                    <div class="h-8 w-8 rounded-lg @iconInfo.Item3 flex items-center justify-center shrink-0">
                                        <i class="bi @iconInfo.Item1 @iconInfo.Item2 text-sm"></i>
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-white/90">@alert.Title</div>
                                        <div class="text-xs text-white/50 mt-1 line-clamp-2">@alert.Message</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-sm text-white/40 text-center py-6 flex flex-col items-center">
                            <i class="bi bi-check-circle text-2xl mb-2 text-white/20"></i>
                            Sin alertas pendientes
                        </div>
                    }
                </section>

                <!-- 2. Pagos Recurrentes -->
                <section class="ft-section flex-1">
                    <h3 class="text-base font-semibold mb-4 border-b border-white/10 pb-3">Pagos Recurrentes</h3>
                    @if (Model.Summary.UpcomingPayments != null && Model.Summary.UpcomingPayments.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var payment in Model.Summary.UpcomingPayments.Take(3))
                            {
                                <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
                                    <div class="flex items-center gap-3">
                                        <div class="h-8 w-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
                                            <i class="bi bi-arrow-repeat text-white/60"></i>
                                        </div>
                                        <div>
                                            <div class="text-sm font-medium text-white/90">@payment.Description</div>
                                            <div class="text-[10px] uppercase text-white/40 mt-0.5">@payment.RecurringPattern</div>
                                        </div>
                                    </div>
                                    <div class="text-sm font-semibold text-red-400">-@FormatCurrency(payment.Amount)</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-sm text-white/40 text-center py-6">
                            No tienes pagos recurrentes configurados.
                        </div>
                    }
                </section>

            </div>
        </div>
    }
</div>

<!-- SCRIPTS DE GRÁFICAS INTACTOS -->
<script id="dashboard-chart-data" type="application/json">
    @Html.Raw(chartJson)
</script>
<script id="category-expense-chart-data" type="application/json">
    @Html.Raw(JsonSerializer.Serialize(new
    {
            labels = Model.Summary.CategorySummaries.Select(x => x.CategoryName).ToList(),
                amounts = Model.Summary.CategorySummaries.Select(x => x.Amount).ToList(),
                colors = Model.Summary.CategorySummaries.Select(x => x.Color).ToList()
        }))
</script>

<script id="net-balance-chart-data" type="application/json">
    @Html.Raw(JsonSerializer.Serialize(new
        {
            labels = Model.Summary.ChartLabels,
                balances = Model.Summary.ChartIncomeData
        }))
</script>

@section Scripts {
    <script>
        (() => {
            function parseJsonScript(id) {
                const el = document.getElementById(id);
                if (!el) {
                    console.warn(`No se encontró el bloque JSON: ${id}`);
                    return null;
                }

                try {
                    return JSON.parse(el.textContent || "{}");
                } catch (error) {
                    console.error(`Error parseando JSON para ${id}`, error);
                    return null;
                }
            }

            function destroyIfExists(name) {
                if (window[name]) {
                    window[name].destroy();
                }
            }

            // ===== GRÁFICO PRINCIPAL =====
            const mainCanvas = document.getElementById('dashboardChart');
            const mainData = parseJsonScript('dashboard-chart-data');

            if (mainCanvas && mainData) {
                destroyIfExists('dashboardChartInstance');

                const labels = Array.isArray(mainData.labels) ? mainData.labels :[];
                const incomeData = Array.isArray(mainData.income) ? mainData.income.map(x => Number(x) || 0) :[];
                const expenseData = Array.isArray(mainData.expense) ? mainData.expense.map(x => Number(x) || 0) :[];

                window.dashboardChartInstance = new Chart(mainCanvas.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: labels.length ? labels : ['Sin datos'],
                        datasets:[
                            {
                                label: 'Ingresos',
                                data: incomeData.length ? incomeData :[0],
                                borderColor: '#22c55e',
                                backgroundColor: 'rgba(34, 197, 94, 0.15)',
                                borderWidth: 3,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                fill: false,
                                tension: 0.35
                            },
                            {
                                label: 'Gastos',
                                data: expenseData.length ? expenseData : [0],
                                borderColor: '#ef4444',
                                backgroundColor: 'rgba(239, 68, 68, 0.15)',
                                borderWidth: 3,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                fill: false,
                                tension: 0.35
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                labels: { color: '#e5e7eb' }
                            }
                        },
                        scales: {
                            x: {
                                ticks: { color: '#9ca3af' },
                                grid: { color: 'rgba(255,255,255,0.06)' }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: { color: '#9ca3af' },
                                grid: { color: 'rgba(255,255,255,0.06)' }
                            }
                        }
                    }
                });
            }

            // ===== GRÁFICO DE PASTEL =====
            const categoryCanvas = document.getElementById('categoryExpenseChart');
            const categoryData = parseJsonScript('category-expense-chart-data');

            if (categoryCanvas && categoryData) {
                destroyIfExists('categoryExpenseChartInstance');

                const labels = Array.isArray(categoryData.labels) ? categoryData.labels :[];
                const amounts = Array.isArray(categoryData.amounts) ? categoryData.amounts.map(x => Number(x) || 0) :[];
                const colors = Array.isArray(categoryData.colors) ? categoryData.colors.map(x => x || '#22c55e') :[];

                const filtered = labels
                    .map((label, index) => ({
                        label,
                        amount: Number(amounts[index]) || 0,
                        color: colors[index] || '#22c55e'
                    }))
                    .filter(x => x.amount > 0);

                const finalLabels = filtered.length ? filtered.map(x => x.label) : ['Sin datos'];
                const finalAmounts = filtered.length ? filtered.map(x => x.amount) : [1];
                const finalColors = filtered.length ? filtered.map(x => x.color) : ['#22c55e'];

                window.categoryExpenseChartInstance = new Chart(categoryCanvas.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: finalLabels,
                        datasets:[{
                            label: 'Gastos por categoría',
                            data: finalAmounts,
                            backgroundColor: finalColors,
                            borderColor: '#1f2937',
                            borderWidth: 2,
                            hoverOffset: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '58%',
                        radius: '88%',
                        plugins: {
                            legend: {
                                display: true,
                                position: 'bottom',
                                labels: {
                                    color: '#e5e7eb',
                                    padding: 14,
                                    usePointStyle: true,
                                    pointStyle: 'circle'
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        const value = Number(context.raw || 0);
                                        return `${context.label}: $${value.toLocaleString()}`;
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // ===== GRÁFICO DE BALANCE NETO =====
            const netCanvas = document.getElementById('netBalanceChart');
            const netData = parseJsonScript('net-balance-chart-data');

            if (netCanvas && netData) {
                destroyIfExists('netBalanceChartInstance');

                const labels = Array.isArray(netData.labels) ? netData.labels :[];
                const balances = Array.isArray(netData.balances) ? netData.balances.map(x => Number(x) || 0) :[];

                window.netBalanceChartInstance = new Chart(netCanvas.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: labels.length ? labels : ['Sin datos'],
                        datasets:[{
                            label: 'Balance neto',
                            data: balances.length ? balances : [0],
                            backgroundColor: balances.map(x => x >= 0 ? 'rgba(34,197,94,0.65)' : 'rgba(239,68,68,0.65)'),
                            borderColor: balances.map(x => x >= 0 ? '#22c55e' : '#ef4444'),
                            borderWidth: 1.5,
                            borderRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                labels: { color: '#e5e7eb' }
                            }
                        },
                        scales: {
                            x: {
                                ticks: { color: '#9ca3af' },
                                grid: { color: 'rgba(255,255,255,0.06)' }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: { color: '#9ca3af' },
                                grid: { color: 'rgba(255,255,255,0.06)' }
                            }
                        }
                    }
                });
            }
        })();
    </script>
}