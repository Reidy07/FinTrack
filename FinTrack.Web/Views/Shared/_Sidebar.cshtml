@{
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();

    Func<string, string> itemClasses = name =>
        controller == name
            ? "flex items-center gap-3 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 py-3 text-sm font-medium text-emerald-200 transition"
            : "flex items-center gap-3 rounded-2xl border border-transparent px-4 py-3 text-sm font-medium text-white/65 transition hover:border-white/10 hover:bg-white/5 hover:text-white";
}

<nav class="space-y-2 lg:space-y-2">
    <a class="@itemClasses("Dashboard")" asp-controller="Dashboard" asp-action="Index">
        <i class="bi bi-grid-1x2"></i>
        <span>Dashboard</span>
    </a>

    <a class="@itemClasses("Expense")" asp-controller="Expense" asp-action="Index">
        <i class="bi bi-wallet2"></i>
        <span>Gastos</span>
    </a>

    <a class="@itemClasses("Income")" asp-controller="Income" asp-action="Index">
        <i class="bi bi-graph-up-arrow"></i>
        <span>Ingresos</span>
    </a>

    <a class="@itemClasses("Category")" asp-controller="Category" asp-action="Index">
        <i class="bi bi-folder"></i>
        <span>Categorías</span>
    </a>

    <a class="@itemClasses("Reports")" asp-controller="Reports" asp-action="Index">
        <i class="bi bi-file-earmark-bar-graph"></i>
        <span>Reportes</span>
    </a>

    <div class="hidden px-2 pt-5 text-[11px] uppercase tracking-[0.24em] text-white/30 lg:block">Inteligencia</div>

    <a class="@itemClasses("Predictions")" asp-controller="Predictions" asp-action="Index">
        <i class="bi bi-stars text-emerald-300"></i>
        <span>Predicciones IA</span>
    </a>

    <a class="@itemClasses("Alerts")" asp-controller="Alerts" asp-action="Index">
        <i class="bi bi-bell"></i>
        <span>Alertas</span>
    </a>
</nav>
