@using FinTrack.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isSignedIn = SignInManager.IsSignedIn(User);

    ApplicationUser? user = null;
    string firstName = "Usuario";
    string lastName = string.Empty;
    string email = User.Identity?.Name ?? string.Empty;
    string initials = "U";

    if (isSignedIn)
    {
        user = await UserManager.GetUserAsync(User);
        firstName = user?.FirstName ?? "Usuario";
        lastName = user?.LastName ?? string.Empty;
        email = user?.Email ?? User.Identity?.Name ?? string.Empty;

        var firstInitial = string.IsNullOrWhiteSpace(firstName) ? "U" : firstName[0].ToString().ToUpper();
        var lastInitial = string.IsNullOrWhiteSpace(lastName) ? string.Empty : lastName[0].ToString().ToUpper();
        initials = $"{firstInitial}{lastInitial}";
    }

    var brandController = isSignedIn ? "Dashboard" : "Home";
    var brandAction = "Index";
    var logoutReturnUrl = Url.Action("Index", "Home", new { area = "" });
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinTrack</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link rel="stylesheet" href="~/fontawesome-free-7.2.0-web/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="ft-app-bg">
    <div class="ft-app-grid" aria-hidden="true"></div>

    <div class="ft-app-shell">
        <div class="ft-sidebar-overlay"></div>

        <button type="button" class="ft-sidebar-toggle" aria-label="Abrir menú">
            <i class="fa-solid fa-bars"></i>
        </button>

        <div class="ft-dashboard-layout">
            <aside class="ft-sidebar" id="appSidebar">
                <div class="ft-sidebar__panel">
                    <div class="ft-sidebar__brand">
                        <a asp-controller="@brandController" asp-action="@brandAction" class="ft-brand">
                            <img src="~/logo.svg" alt="FinTrack" class="ft-brand__logo" />
                            <span class="ft-brand__text">
                                <span class="ft-brand__title">FinTrack</span>
                                <span class="ft-brand__subtitle">Control financiero personal</span>
                            </span>
                        </a>
                    </div>

                    @if (isSignedIn)
                    {
                        <nav class="ft-sidebar__nav">
                            <ul class="ft-stack-md">
                                <li>
                                    <a asp-controller="Dashboard"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Dashboard" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-table-columns"></i>
                                        <span>Dashboard</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Expense"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Expense" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-wallet"></i>
                                        <span>Gastos</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Income"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Income" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-chart-line"></i>
                                        <span>Ingresos</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Category"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Category" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-folder-open"></i>
                                        <span>Categorías</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Reports"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Reports" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-chart-pie"></i>
                                        <span>Reportes</span>
                                    </a>
                                </li>
                            </ul>

                            <div class="ft-sidebar__section-title">Inteligencia</div>

                            <ul class="ft-stack-md">
                                <li>
                                    <a asp-controller="Predictions"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Predictions" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-sparkles"></i>
                                        <span>Predicciones IA</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Chatbot"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Chatbot" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-robot"></i>
                                        <span>Asesor IA (Chat)</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Alerts"
                                           asp-action="Index"
                                           class="ft-nav-link @((currentController == "Alerts" && currentAction == "Index") ? "active" : "")">
                                        <i class="fas fa-bell"></i>
                                        <span>Alertas</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>

                        <div class="ft-sidebar__footer">
                            <div class="ft-user-card">
                                <div class="ft-user-card__avatar">
                                    @initials
                                </div>
                                <div>
                                    <div class="ft-user-card__name">@firstName @lastName</div>
                                    <div class="ft-user-card__link">@email</div>
                                </div>
                            </div>

                            <form asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  asp-route-returnUrl="@logoutReturnUrl"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="ft-logout-btn">
                                    <i class="fas fa-right-from-bracket"></i>
                                    <span>Cerrar sesión</span>
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="ft-sidebar__footer">
                            <a asp-area="Identity" asp-page="/Account/Login" class="ft-nav-link">
                                <i class="fas fa-right-to-bracket"></i>
                                <span>Iniciar sesión</span>
                            </a>

                            <a asp-area="Identity" asp-page="/Account/Register" class="ft-nav-link">
                                <i class="fas fa-user-plus"></i>
                                <span>Crear cuenta</span>
                            </a>
                        </div>
                    }
                </div>
            </aside>

            <main class="ft-main">
                <div class="ft-main__panel">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_Notifications" />

</body>
</html>