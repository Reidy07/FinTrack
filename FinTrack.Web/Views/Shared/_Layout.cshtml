@using Microsoft.AspNetCore.Identity
@using FinTrack.Infrastructure.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="icon" type="image/svg+xml" href="~/logo.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="ft-app-bg">
    <div class="ft-app-grid" aria-hidden="true"></div>

    @{
        var isSignedIn = SignInManager.IsSignedIn(User);
        var user = isSignedIn ? await UserManager.GetUserAsync(User) : null;
        var userName = user?.FirstName ?? User.Identity?.Name ?? "Usuario";
        var userInitial = string.IsNullOrWhiteSpace(userName) ? "U" : userName[..1].ToUpper();
    }

    <div class="ft-app-shell">
        @if (isSignedIn)
        {
            <div class="ft-dashboard-layout">
                <header class="ft-mobile-topbar">
                    <div class="ft-mobile-topbar__inner">
                        <a asp-controller="Dashboard" asp-action="Index" class="ft-brand">
                            <img src="~/images/fintrack-logo.jpg" asp-append-version="true" class="ft-brand__logo" alt="FinTrack" />
                            <div class="ft-brand__text">
                                <span class="ft-brand__title">FinTrack</span>
                                <span class="ft-brand__subtitle">Control financiero personal</span>
                            </div>
                        </a>

                        <div class="flex items-center gap-2">
                            <a asp-controller="Alerts" asp-action="Index" class="ft-icon-btn" title="Alertas">
                                <i class="bi bi-bell"></i>
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="ft-icon-btn" title="Mi perfil">
                                <span class="text-sm font-semibold">@userInitial</span>
                            </a>
                        </div>
                    </div>
                </header>

                <div class="ft-mobile-nav">
                    <partial name="_Sidebar" />
                </div>

                <aside class="ft-sidebar">
                    <div class="ft-sidebar__panel">
                        <div class="ft-sidebar__brand">
                            <a asp-controller="Dashboard" asp-action="Index" class="ft-brand">
                                <img src="~/images/fintrack-logo.jpg" asp-append-version="true" class="ft-brand__logo" alt="FinTrack" />
                                <div class="ft-brand__text">
                                    <span class="ft-brand__title">FinTrack</span>
                                    <span class="ft-brand__subtitle">Control financiero personal</span>
                                </div>
                            </a>
                        </div>

                        <div class="ft-sidebar__nav">
                            <partial name="_Sidebar" />
                        </div>

                        <div class="ft-sidebar__footer">
                            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="ft-user-card">
                                <div class="ft-user-card__avatar">@userInitial</div>
                                <div>
                                    <div class="ft-user-card__name">@userName</div>
                                    <div class="ft-user-card__link">Ver perfil</div>
                                </div>
                            </a>

                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="ft-logout-btn">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Cerrar sesión</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </aside>

                <main class="ft-main">
                    <div class="ft-main__panel">
                        @RenderBody()
                    </div>
                </main>
            </div>
        }
        else
        {
            <main class="ft-auth-page">
                @RenderBody()
            </main>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
